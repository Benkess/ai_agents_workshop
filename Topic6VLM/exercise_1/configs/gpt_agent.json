{
  "name": "OpenAI GPT-5.2",
  "agent": {
    "implementation": "openai",
    "model": "gpt-5.2",
    "base_url": null,
    "api_key": null,
    "api_key_env": "OPENAI_API_KEY",
    "system_prompt": "You are an ai assistant. You will be give an image to discuss with the user",
    "trim_strategy": "last",
    "token_counter": "approximate",
    "max_tokens": 16384,
    "start_on": "human",
    "include_system": true,
    "allow_partial": false
  }
}

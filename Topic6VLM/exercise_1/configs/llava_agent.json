{
  "name": "Ollama LLaVA",
  "agent": {
    "implementation": "openai",
    "model": "llava",
    "base_url": "http://localhost:11434/v1",
    "api_key": "ollama",
    "api_key_env": null,
    "system_prompt": "You are an ai assistant. You will be give an image to discuss with the user",
    "trim_strategy": "last",
    "token_counter": "approximate",
    "max_tokens": 16384,
    "start_on": "human",
    "include_system": true,
    "allow_partial": false
  }
}

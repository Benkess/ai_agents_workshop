{
  "name": "OpenAI Default",
  "agent": {
    "implementation": "openai",
    "model": "gpt-4o-mini",
    "base_url": null,
    "api_key": null,
    "api_key_env": "OPENAI_API_KEY",
    "system_prompt": "You are a helpful assistant.",
    "trim_strategy": "last",
    "token_counter": "approximate",
    "max_tokens": 512,
    "start_on": "human",
    "include_system": true,
    "allow_partial": false
  }
}
